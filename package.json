{
  "name": "inventory-backend-api",
  "version": "1.0.0",
  "description": "Backend API for Inventory Control System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc && node scripts/post-build.js",
    "start": "node dist/server.js",
    "test": "jest",
    "create-admin": "ts-node src/scripts/createAdmin.ts",
