# ============================================
# BACKEND ENVIRONMENT VARIABLES - EXAMPLE
# ============================================
# Copia este archivo a .env para desarrollo
# Copia este archivo a .env.production para producción

# ============================================
# SERVER CONFIGURATION
# ============================================
# Puerto en el que corre el servidor
PORT=3000

# Entorno de ejecución (development, production, test)
NODE_ENV=development

# Host del servidor (0.0.0.0 para permitir conexiones externas)
HOST=0.0.0.0

# ============================================
# DATABASE CONFIGURATION
# ============================================
# Ruta a la base de datos SQLite
DB_PATH=./database/inventory.sqlite

# Habilitar logging de queries SQL (true/false)
DB_LOGGING=true

# Habilitar sincronización automática de modelos (true/false)
# ADVERTENCIA: En producción debe ser false
DB_SYNC=true

# Forzar recreación de tablas (true/false)
# ADVERTENCIA: Esto borra todos los datos
DB_FORCE_SYNC=false

# ============================================
# JWT CONFIGURATION
# ============================================
# Clave secreta para firmar tokens JWT
# IMPORTANTE: Cambia esto en producción por una clave segura
# Genera una con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-secret-key-change-this-in-production-use-a-long-random-string

# Tiempo de expiración del token (ejemplos: 1h, 24h, 7d, 30d)
JWT_EXPIRES_IN=24h

# Tiempo de expiración del refresh token
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# CORS CONFIGURATION
# ============================================
# Origen permitido para CORS (URL del frontend)
# Desarrollo: http://localhost:8080
# Producción: https://tu-frontend.netlify.app
CORS_ORIGIN=http://localhost:8080

# Permitir múltiples orígenes (separados por coma)
# CORS_ORIGIN=http://localhost:8080,https://tu-frontend.netlify.app

# ============================================
# LOGGING CONFIGURATION
# ============================================
# Nivel de logging (error, warn, info, debug)
LOG_LEVEL=info

# Habilitar logs en archivo (true/false)
LOG_TO_FILE=false

# Ruta del archivo de logs
LOG_FILE_PATH=./logs/app.log

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
# Directorio para subir archivos
UPLOAD_DIR=./uploads

# Tamaño máximo de archivo en bytes (5MB = 5242880)
MAX_FILE_SIZE=5242880

# Tipos de archivo permitidos (separados por coma)
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ============================================
# SECURITY CONFIGURATION
# ============================================
# Habilitar rate limiting (true/false)
RATE_LIMIT_ENABLED=true

# Máximo de requests por ventana de tiempo
RATE_LIMIT_MAX=100

# Ventana de tiempo en minutos
RATE_LIMIT_WINDOW=15

# Habilitar helmet (seguridad HTTP headers)
HELMET_ENABLED=true

# ============================================
# EMAIL CONFIGURATION (Opcional)
# ============================================
# Configuración de email para notificaciones
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu-email@gmail.com
EMAIL_PASSWORD=tu-password-de-aplicacion
EMAIL_FROM=Sistema de Inventario <noreply@inventario.com>

# ============================================
# NOTIFICATION CONFIGURATION
# ============================================
# Habilitar notificaciones automáticas
NOTIFICATIONS_ENABLED=true

# Días antes de vencimiento para notificar
EXPIRY_WARNING_DAYS=7

# Porcentaje de stock bajo para notificar (0-100)
LOW_STOCK_THRESHOLD=20

# ============================================
# SESSION CONFIGURATION
# ============================================
# Tiempo de inactividad antes de cerrar sesión (en milisegundos)
# 3 minutos = 180000
SESSION_INACTIVITY_TIMEOUT=180000

# ============================================
# API CONFIGURATION
# ============================================
# Prefijo de la API
API_PREFIX=/api

# Versión de la API
API_VERSION=v1

# ============================================
# FRONTEND URL (para redirecciones)
# ============================================
FRONTEND_URL=http://localhost:8080

# ============================================
# BACKUP CONFIGURATION (Opcional)
# ============================================
# Habilitar backups automáticos
BACKUP_ENABLED=false

# Directorio de backups
BACKUP_DIR=./backups

# Intervalo de backup en horas
BACKUP_INTERVAL=24

# ============================================
# ADMIN USER SEED CONFIGURATION
# ============================================
# Credenciales del usuario administrador inicial
# Estas variables se usan al ejecutar: npm run seed:admin
ADMIN_EMAIL=admin@inventario.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Administrador
